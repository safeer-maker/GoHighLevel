# --- REQUIRED ---
# Get these from your GHL sandbox sub-account:
#   - GHL_API_KEY:    Sub-account > Settings > Business Profile > scroll to "API Key" section
#                     (If missing, ask agency admin to enable API access, or create a Private App
#                      at marketplace.gohighlevel.com)
#   - GHL_LOCATION_ID: Look at the URL when inside the sub-account — it contains /location/{ID}/...
GHL_API_KEY=your-sandbox-sub-account-api-key-here
GHL_LOCATION_ID=your-sandbox-location-id-here

# --- OPTIONAL (defaults shown) ---

# v2 API base URL — almost never need to change this
GHL_BASE_URL=https://services.leadconnectorhq.com

# API version header — almost never need to change this
GHL_API_VERSION=2021-07-28

# DEBUG | INFO | WARNING | ERROR
LOG_LEVEL=INFO

# If true, scripts log what they WOULD do but don't fire any mutations.
# Recommended first run: DRY_RUN=true
DRY_RUN=false

# Seconds to sleep between mutating API calls (be polite to GHL)
RATE_LIMIT_DELAY=0.2
