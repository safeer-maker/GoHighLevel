# GoHighLevel API Configuration
# Copy this file to config.py and fill in your credentials
#
# To get your API key:
# 1. Go to Settings > Business Profile > API Keys in your GHL sub-account
# 2. Or use the GHL Developer Marketplace for OAuth2 access
#
# To find your Location ID:
# 1. Go to Settings > Business Profile
# 2. The Location ID is displayed in the URL or in the account info

GHL_API_KEY = "your-api-key-here"
GHL_LOCATION_ID = "your-location-id-here"
GHL_BASE_URL = "https://services.leadconnectorhq.com"

# API Version - GHL uses versioned endpoints
API_VERSION = "2021-07-28"
